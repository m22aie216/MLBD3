   "source": [
    "## Part 2: Collaborative Filtering ##\n",
    "## Task 3 & 4: User-Based Collaborative Filtering &  Item-Based Collaborative Filtering ##\n",
    "\n",
    "from sklearn.metrics import mean_squared_error\n",
    "from math import sqrt\n",
    "\n",
    "user_movie_matrix = ratings.pivot(index='userId', columns='movieId', values='rating')\n",
    "\n",
    "user_movie_filled = user_movie_matrix.fillna(0)\n",
    "\n",
    "user_similarity = cosine_similarity(user_movie_filled)\n",
    "user_similarity_df = pd.DataFrame(user_similarity, \n",
    "                                 index=user_movie_matrix.index, \n",
    "                                 columns=user_movie_matrix.index)\n",
    "\n",
    "def predict_ratings_user(user_id, k=5):\n",
    "    sim_scores = user_similarity_df[user_id].drop(user_id)\n",
    "\n",
    "    # Top-K similar users\n",
    "    top_users = sim_scores.sort_values(ascending=False).head(k)\n",
    "\n",
    "    # Ratings of top users\n",
    "    top_ratings = user_movie_matrix.loc[top_users.index]\n",
    "\n",
    "    # Weighted average\n",
    "    weighted_sum = np.dot(top_users.values, top_ratings.fillna(0))\n",
    "    sim_sum = np.abs(top_users.values).sum()\n",
    "\n",
    "    predictions = weighted_sum / sim_sum\n",
    "\n",
    "    return pd.Series(predictions, index=user_movie_matrix.columns)\n",
    "\n",
    "def recommend_user_based(user_id, k=5, top_n=5):\n",
    "    preds = predict_ratings_user(user_id, k)\n",
    "\n",
    "    # Remove already rated movies\n",
    "    rated = user_movie_matrix.loc[user_id].dropna().index\n",
    "    preds = preds.drop(rated, errors='ignore')\n",
    "\n",
    "    top_movies = preds.sort_values(ascending=False).head(top_n)\n",
    "\n",
    "    return pd.DataFrame({\n",
    "        \"movieId\": top_movies.index,\n",
    "        \"predicted_rating\": top_movies.values\n",
    "    }).merge(movies, on=\"movieId\")[[\"title\", \"predicted_rating\"]]\n",
    "\n",
    "item_similarity = cosine_similarity(user_movie_filled.T)\n",
    "item_similarity_df = pd.DataFrame(item_similarity,\n",
    "                                 index=user_movie_matrix.columns,\n",
    "                                 columns=user_movie_matrix.columns)\n",
    "\n",
    "def predict_ratings_item(user_id):\n",
    "    user_ratings = user_movie_matrix.loc[user_id]\n",
    "\n",
    "    preds = {}\n",
    "\n",
    "    for movie in user_movie_matrix.columns:\n",
    "        if not np.isnan(user_ratings[movie]):\n",
    "            continue\n",
    "\n",
    "        # Similarity with other items\n",
    "        sim_scores = item_similarity_df[movie]\n",
    "\n",
    "        # Only consider rated movies\n",
    "        rated_movies = user_ratings.dropna()\n",
    "\n",
    "        sims = sim_scores[rated_movies.index]\n",
    "        ratings_vals = rated_movies.values\n",
    "\n",
    "        if sims.sum() == 0:\n",
    "            preds[movie] = 0\n",
    "        else:\n",
    "            preds[movie] = np.dot(sims, ratings_vals) / np.abs(sims).sum()\n",
    "\n",
    "    return pd.Series(preds)\n",
    "\n",
    "def recommend_item_based(user_id, top_n=5):\n",
    "    preds = predict_ratings_item(user_id)\n",
    "\n",
    "    top_movies = preds.sort_values(ascending=False).head(top_n)\n",
    "\n",
    "    return pd.DataFrame({\n",
    "        \"movieId\": top_movies.index,\n",
    "        \"predicted_rating\": top_movies.values\n",
    "    }).merge(movies, on=\"movieId\")[[\"title\", \"predicted_rating\"]]\n",
    "\n",
    "def compute_rmse(user_id, k=5):\n",
    "    preds = predict_ratings_user(user_id, k)\n",
    "    actual = user_movie_matrix.loc[user_id].dropna()\n",
    "\n",
    "    common = actual.index.intersection(preds.index)\n",
    "\n",
    "    return sqrt(mean_squared_error(actual[common], preds[common]))\n",
    "\n",
    "def precision_recall_at_k(user_id, k=5, threshold=4.0):\n",
    "    recs = recommend_user_based(user_id, k, k)\n",
    "    recommended_ids = movies[movies['title'].isin(recs['title'])]['movieId']\n",
    "\n",
    "    relevant = ratings[(ratings['userId']==user_id) & (ratings['rating']>=threshold)]['movieId']\n",
    "\n",
    "    recommended_set = set(recommended_ids)\n",
    "    relevant_set = set(relevant)\n",
    "\n",
    "    tp = len(recommended_set & relevant_set)\n",
    "\n",
    "    precision = tp / k if k > 0 else 0\n",
    "    recall = tp / len(relevant_set) if len(relevant_set)>0 else 0\n",
    "\n",
    "    return precision, recall\n",
    "\n",
    "user_id = 1\n",
    "\n",
    "print(\"USER-BASED CF Recommendations:\")\n",
    "print(recommend_user_based(user_id, k=5, top_n=5), \"\\n\")\n",
    "\n",
    "print(\"ITEM-BASED CF Recommendations:\")\n",
    "print(recommend_item_based(user_id, top_n=5), \"\\n\")\n",
    "\n",
    "print(\"RMSE:\", compute_rmse(user_id, k=5))\n",
    "\n",
    "precision, recall = precision_recall_at_k(user_id, k=5)\n",
    "print(\"Precision@5:\", precision)\n",
    "print(\"Recall@5:\", recall)\n",
    "\n",
    "print(\"\\nEffect of K:\")\n",
    "for k in [3,5,10]:\n",
    "    rmse = compute_rmse(user_id, k)\n",
    "    precision, recall = precision_recall_at_k(user_id, k)\n",
    "    print(f\"K={k} -> RMSE={rmse:.3f}, Precision={precision:.3f}, Recall={recall:.3f}\")"
   ]
