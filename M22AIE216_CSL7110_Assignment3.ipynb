   "source": [
    "## Part 3: Matrix Factorization for Recommender Systems ##\n",
    "## Task 5 & Task 6: Implementing SVD for Recommendations & Implementing Matrix Factorization with the Surprise Library ##\n",
    "\n",
    "from surprise import Dataset, Reader, SVD\n",
    "from surprise.model_selection import train_test_split\n",
    "from surprise.accuracy import rmse\n",
    "\n",
    "R = user_movie_matrix.copy()\n",
    "user_mean = R.mean(axis=1)\n",
    "R_filled = R.apply(lambda row: row.fillna(row.mean()), axis=1)\n",
    "R_matrix = R_filled.values\n",
    "\n",
    "U, sigma, Vt = np.linalg.svd(R_matrix, full_matrices=False)\n",
    "sigma_diag = np.diag(sigma)\n",
    "k = 20\n",
    "U_k = U[:, :k]\n",
    "sigma_k = sigma_diag[:k, :k]\n",
    "Vt_k = Vt[:k, :]\n",
    "\n",
    "R_pred = np.dot(np.dot(U_k, sigma_k), Vt_k)\n",
    "R_pred = R_pred + user_mean.values.reshape(-1, 1)\n",
    "R_pred = np.clip(R_pred, 1, 5)\n",
    "R_pred_df = pd.DataFrame(R_pred, index=R.index, columns=R.columns)\n",
    "\n",
    "def recommend_svd(user_id, top_n=5):\n",
    "    preds = R_pred_df.loc[user_id]\n",
    "\n",
    "    rated = user_movie_matrix.loc[user_id].dropna().index\n",
    "    preds = preds.drop(rated, errors='ignore')\n",
    "\n",
    "    top_movies = preds.sort_values(ascending=False).head(top_n)\n",
    "\n",
    "    return pd.DataFrame({\n",
    "        \"movieId\": top_movies.index,\n",
    "        \"predicted_rating\": top_movies.values\n",
    "    }).merge(movies, on=\"movieId\")[[\"title\", \"predicted_rating\"]]\n",
    "\n",
    "def rmse_svd(user_id):\n",
    "    actual = user_movie_matrix.loc[user_id].dropna()\n",
    "    preds = R_pred_df.loc[user_id]\n",
    "\n",
    "    common = actual.index.intersection(preds.index)\n",
    "\n",
    "    return np.sqrt(np.mean((actual[common] - preds[common])**2))\n",
    "\n",
    "def precision_recall_svd(user_id, k=5, threshold=4.0):\n",
    "    recs = recommend_svd(user_id, k)\n",
    "\n",
    "    recommended_ids = movies[movies['title'].isin(recs['title'])]['movieId']\n",
    "    relevant = ratings[(ratings['userId']==user_id) & (ratings['rating']>=threshold)]['movieId']\n",
    "\n",
    "    recommended_set = set(recommended_ids)\n",
    "    relevant_set = set(relevant)\n",
    "\n",
    "    tp = len(recommended_set & relevant_set)\n",
    "\n",
    "    precision = tp / k if k > 0 else 0\n",
    "    recall = tp / len(relevant_set) if len(relevant_set)>0 else 0\n",
    "\n",
    "    return precision, recall\n",
    "\n",
    "user_id = 1\n",
    "\n",
    "print(\"SVD Recommendations:\")\n",
    "print(recommend_svd(user_id, 5), \"\\n\")\n",
    "\n",
    "print(\"SVD RMSE:\", rmse_svd(user_id))\n",
    "\n",
    "p, r = precision_recall_svd(user_id, 5)\n",
    "print(\"Precision@5:\", p)\n",
    "print(\"Recall@5:\", r)\n",
    "\n",
    "reader = Reader(rating_scale=(0.5, 5))\n",
    "data = Dataset.load_from_df(ratings[['userId','movieId','rating']], reader)\n",
    "\n",
    "trainset, testset = train_test_split(data, test_size=0.2, random_state=42)\n",
    "\n",
    "svd_model = SVD(n_factors=50, n_epochs=20, lr_all=0.005, reg_all=0.02)\n",
    "svd_model.fit(trainset)\n",
    "\n",
    "predictions = svd_model.test(testset)\n",
    "print(\"\\nSurprise SVD RMSE:\")\n",
    "rmse(predictions)\n",
    "\n",
    "def precision_recall_surprise(predictions, k=5, threshold=4.0):\n",
    "    from collections import defaultdict\n",
    "\n",
    "    user_est_true = defaultdict(list)\n",
    "\n",
    "    for uid, iid, true_r, est, _ in predictions:\n",
    "        user_est_true[uid].append((est, true_r))\n",
    "\n",
    "    precisions = {}\n",
    "    recalls = {}\n",
    "\n",
    "    for uid, user_ratings in user_est_true.items():\n",
    "        user_ratings.sort(key=lambda x: x[0], reverse=True)\n",
    "\n",
    "        top_k = user_ratings[:k]\n",
    "\n",
    "        relevant = sum((true_r >= threshold) for (_, true_r) in user_ratings)\n",
    "        recommended = sum((est >= threshold) for (est, _) in top_k)\n",
    "        tp = sum((true_r >= threshold and est >= threshold) for (est, true_r) in top_k)\n",
    "\n",
    "        precisions[uid] = tp / recommended if recommended > 0 else 0\n",
    "        recalls[uid] = tp / relevant if relevant > 0 else 0\n",
    "\n",
    "    return np.mean(list(precisions.values())), np.mean(list(recalls.values()))\n",
    "\n",
    "p_s, r_s = precision_recall_surprise(predictions, k=5)\n",
    "\n",
    "print(\"Surprise Precision@5:\", p_s)\n",
    "print(\"Surprise Recall@5:\", r_s)\n"
   ]
  },
