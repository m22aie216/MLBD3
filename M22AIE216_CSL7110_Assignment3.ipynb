   "source": [
    "## Part 5: Learning-Based Recommender Systems ##\n",
    "## Task 8 & Task 9: Content-Based Filtering with a Neural Network & Reinforcement Learning in Recommender Systems ##\n",
    "\n",
    "from sklearn.preprocessing import MultiLabelBinarizer\n",
    "from sklearn.model_selection import train_test_split\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras.layers import Input, Dense, Concatenate\n",
    "from tensorflow.keras.models import Model\n",
    "\n",
    "movies['year'] = movies['title'].str.extract(r'\\((\\d{4})\\)').astype(float)\n",
    "movies['year'] = movies['year'].fillna(movies['year'].mean())\n",
    "\n",
    "movies['genres_list'] = movies['genres'].str.split('|')\n",
    "mlb = MultiLabelBinarizer()\n",
    "genre_encoded = pd.DataFrame(mlb.fit_transform(movies['genres_list']),\n",
    "                             columns=mlb.classes_,\n",
    "                             index=movies.index)\n",
    "\n",
    "movie_avg = ratings.groupby('movieId')['rating'].mean()\n",
    "\n",
    "movie_features = movies[['movieId','year']].join(genre_encoded)\n",
    "movie_features['avg_rating'] = movie_features['movieId'].map(movie_avg)\n",
    "movie_features = movie_features.fillna(0)\n",
    "\n",
    "user_genre_pref = {}\n",
    "\n",
    "for user in ratings['userId'].unique():\n",
    "    user_data = ratings[ratings['userId']==user]\n",
    "    merged = user_data.merge(movies[['movieId','genres_list']], on='movieId')\n",
    "\n",
    "    genre_scores = {g:[] for g in mlb.classes_}\n",
    "    for _, row in merged.iterrows():\n",
    "        for g in row['genres_list']:\n",
    "            genre_scores[g].append(row['rating'])\n",
    "\n",
    "    genre_avg = {g:(np.mean(v) if len(v)>0 else 0) for g,v in genre_scores.items()}\n",
    "    user_genre_pref[user] = genre_avg\n",
    "\n",
    "user_features = pd.DataFrame(user_genre_pref).T.fillna(0)\n",
    "\n",
    "\n",
    "X_user = []\n",
    "X_movie = []\n",
    "y = []\n",
    "\n",
    "for _, row in ratings.iterrows():\n",
    "    u = row['userId']\n",
    "    m = row['movieId']\n",
    "\n",
    "    if m not in movie_features['movieId'].values:\n",
    "        continue\n",
    "\n",
    "    X_user.append(user_features.loc[u].values)\n",
    "    X_movie.append(movie_features[movie_features['movieId']==m].drop('movieId',axis=1).values[0])\n",
    "    y.append(row['rating'])\n",
    "\n",
    "X_user = np.array(X_user)\n",
    "X_movie = np.array(X_movie)\n",
    "y = np.array(y)\n",
    "\n",
    "X_user_train, X_user_test, X_movie_train, X_movie_test, y_train, y_test = train_test_split(\n",
    "    X_user, X_movie, y, test_size=0.2, random_state=42\n",
    ")\n",
    "\n",
    "user_input = Input(shape=(X_user.shape[1],))\n",
    "user_dense = Dense(64, activation='relu')(user_input)\n",
    "user_emb = Dense(32, activation='relu')(user_dense)\n",
    "\n",
    "movie_input = Input(shape=(X_movie.shape[1],))\n",
    "movie_dense = Dense(64, activation='relu')(movie_input)\n",
    "movie_emb = Dense(32, activation='relu')(movie_dense)\n",
    "\n",
    "merged = Concatenate()([user_emb, movie_emb])\n",
    "x = Dense(64, activation='relu')(merged)\n",
    "output = Dense(1)(x)\n",
    "\n",
    "model = Model([user_input, movie_input], output)\n",
    "model.compile(optimizer='adam', loss='mse')\n",
    "\n",
    "model.fit([X_user_train, X_movie_train], y_train,\n",
    "          validation_data=([X_user_test, X_movie_test], y_test),\n",
    "          epochs=5, batch_size=256, verbose=1)\n",
    "\n",
    "preds = model.predict([X_user_test, X_movie_test])\n",
    "rmse_nn = np.sqrt(np.mean((y_test - preds.flatten())**2))\n",
    "\n",
    "print(\"Neural Model RMSE:\", rmse_nn)\n",
    "\n",
    "movie_ids = ratings['movieId'].unique()\n",
    "reward_estimates = {m:0 for m in movie_ids}\n",
    "counts = {m:0 for m in movie_ids}\n",
    "\n",
    "epsilon = 0.1\n",
    "\n",
    "def get_reward(user, movie):\n",
    "    r = ratings[(ratings['userId']==user) & (ratings['movieId']==movie)]\n",
    "    if len(r)==0:\n",
    "        return 0\n",
    "    return 1 if r.iloc[0]['rating'] >= 4 else -1\n",
    "\n",
    "for _ in range(5000):\n",
    "    user = np.random.choice(ratings['userId'].unique())\n",
    "\n",
    "    if np.random.rand() < epsilon:\n",
    "        movie = np.random.choice(movie_ids)  # explore\n",
    "    else:\n",
    "        movie = max(reward_estimates, key=reward_estimates.get)  # exploit\n",
    "\n",
    "    reward = get_reward(user, movie)\n",
    "\n",
    "    counts[movie] += 1\n",
    "    reward_estimates[movie] += (reward - reward_estimates[movie]) / counts[movie]\n",
    "\n",
    "top_bandit = sorted(reward_estimates.items(), key=lambda x: x[1], reverse=True)[:5]\n",
    "print(\"\\nBandit Recommendations:\", top_bandit)\n",
    "\n",
    "Q = {}  # (user, movie) → value\n",
    "alpha = 0.1\n",
    "gamma = 0.9\n",
    "epsilon = 0.1\n",
    "\n",
    "def get_q(user, movie):\n",
    "    return Q.get((user, movie), 0)\n",
    "\n",
    "for _ in range(5000):\n",
    "    user = np.random.choice(ratings['userId'].unique())\n",
    "\n",
    "    # ε-greedy\n",
    "    if np.random.rand() < epsilon:\n",
    "        movie = np.random.choice(movie_ids)\n",
    "    else:\n",
    "        movie = max(movie_ids, key=lambda m: get_q(user, m))\n",
    "\n",
    "    reward = get_reward(user, movie)\n",
    "\n",
    "    max_future = max([get_q(user, m) for m in movie_ids])\n",
    "    old_q = get_q(user, movie)\n",
    "\n",
    "    new_q = old_q + alpha * (reward + gamma * max_future - old_q)\n",
    "    Q[(user, movie)] = new_q\n",
    "\n",
    "def recommend_q(user_id, top_n=5):\n",
    "    scores = [(m, get_q(user_id, m)) for m in movie_ids]\n",
    "    scores = sorted(scores, key=lambda x: x[1], reverse=True)[:top_n]\n",
    "    return scores\n",
    "\n",
    "print(\"\\nQ-Learning Recommendations:\", recommend_q(1))"
   ]
